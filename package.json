{
  "name": "human-invention-game",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 0.0.0.0",
    "assets:generate": "if [ -x .venv/bin/python ]; then .venv/bin/python scripts/generate-vector-model-assets.py; else python3 scripts/generate-vector-model-assets.py; fi",
    "build": "next build",
    "start": "next start -H 0.0.0.0",
    "lint": "next typegen && tsc --noEmit",
    "typecheck": "next typegen && tsc --noEmit",
    "deploy": "scripts/deploy-vercel.sh production",
    "deploy:prod": "scripts/deploy-vercel.sh production",
    "deploy:preview": "scripts/deploy-vercel.sh preview"
  },
  "dependencies": {
    "firebase-admin": "^14.0.0",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "typescript": "latest"
  }
}
